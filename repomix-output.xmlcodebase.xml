              borderRadius: BorderRadius.circular(15),
            ),
            child: Icon(feature.icon, color: Colors.white, size: 40),
          ),
          const SizedBox(height: 8),
          Text(
            feature.title,
            textAlign: TextAlign.center,
            style: const TextStyle(fontSize: 12),
          ),
        ],
      ),
    );
  }
}
